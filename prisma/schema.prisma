// Perseus Platform — Prisma Schema
// Phase 1: Data Model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
  DOWNLOAD
  MIXED
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum OfferType {
  ONE_TIME
  SUBSCRIPTION
  PAYMENT_PLAN
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum ImportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ImportType {
  COURSE
}

// ─── Auth (NextAuth standard) ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  instructor    Instructor?
  enrollments   Enrollment[]
  orders        Order[]
  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Instructors ──────────────────────────────────────────────────────────────

model Instructor {
  id        String   @id @default(cuid())
  name      String
  bio       String?
  avatar    String?
  website   String?
  twitter   String?
  linkedin  String?
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  courses Course[]
}

// ─── Courses & Content ────────────────────────────────────────────────────────

model Course {
  id               String       @id @default(cuid())
  slug             String       @unique
  title            String
  subtitle         String?
  description      String?
  status           CourseStatus @default(DRAFT)
  thumbnailUrl     String?
  previewVideoUrl  String?
  learningOutcomes Json?
  whoItsFor        Json?
  includes         Json?
  instructorId     String
  legacy_url       String?      @unique
  legacy_id        String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  instructor    Instructor     @relation(fields: [instructorId], references: [id])
  modules       Module[]
  faqs          FAQ[]
  testimonials  Testimonial[]
  generatedPage GeneratedPage?
  enrollments   Enrollment[]
  offers        Offer[]
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  position  Int
  createdAt DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, position])
}

model Lesson {
  id          String       @id @default(cuid())
  moduleId    String
  title       String
  type        LessonType   @default(VIDEO)
  status      LessonStatus @default(DRAFT)
  position    Int
  videoUrl    String?
  content     String?
  downloadUrl String?
  drip_days   Int?
  isPreview   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, position])
}

model FAQ {
  id        String @id @default(cuid())
  courseId  String
  question  String
  answer    String
  position  Int

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, position])
}

model Testimonial {
  id        String   @id @default(cuid())
  courseId  String
  name      String
  role      String?
  avatar    String?
  body      String
  rating    Int?
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model GeneratedPage {
  id             String   @id @default(cuid())
  courseId       String   @unique
  payload        Json
  overrideActive Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ─── Commerce ─────────────────────────────────────────────────────────────────

model Offer {
  id        String    @id @default(cuid())
  courseId  String
  name      String
  type      OfferType @default(ONE_TIME)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  prices        Price[]
  orders        Order[]
  coupons       Coupon[]
  subscriptions Subscription[]
}

model Price {
  id              String   @id @default(cuid())
  offerId         String
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  billingInterval String?
  intervalCount   Int?
  trialDays       Int?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())

  offer  Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Coupon {
  id              String    @id @default(cuid())
  offerId         String
  code            String    @unique
  discountPercent Decimal   @db.Decimal(5, 2)
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  offer  Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  offerId        String
  priceId        String
  status         OrderStatus @default(PENDING)
  totalAmount    Decimal     @db.Decimal(10, 2)
  currency       String      @default("USD")
  couponId       String?
  gatewayOrderId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  offer      Offer       @relation(fields: [offerId], references: [id])
  price      Price       @relation(fields: [priceId], references: [id])
  coupon     Coupon?     @relation(fields: [couponId], references: [id])
  payment    Payment?
  enrollment Enrollment?
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String        @unique
  gatewayId        String
  gatewayPaymentId String
  status           PaymentStatus @default(PENDING)
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  rawEvent         Json?
  createdAt        DateTime      @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  gateway Gateway @relation(fields: [gatewayId], references: [id])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  offerId          String
  gatewayId        String
  gatewaySubId     String
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  offer   Offer   @relation(fields: [offerId], references: [id])
  gateway Gateway @relation(fields: [gatewayId], references: [id])
}

model Enrollment {
  id         String    @id @default(cuid())
  userId     String
  courseId   String
  orderId    String    @unique
  enrolledAt DateTime  @default(now())
  expiresAt  DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([userId, courseId])
}

// ─── Payment Infrastructure ───────────────────────────────────────────────────

model Gateway {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  credentials   GatewayCredential[]
  payments      Payment[]
  subscriptions Subscription[]
  webhookEvents WebhookEvent[]
}

model GatewayCredential {
  id             String   @id @default(cuid())
  gatewayId      String
  key            String
  encryptedValue String
  createdAt      DateTime @default(now())

  gateway Gateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@unique([gatewayId, key])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  gatewayId  String
  eventType  String
  rawPayload Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  gateway Gateway @relation(fields: [gatewayId], references: [id])
}

// ─── Admin / Migration ────────────────────────────────────────────────────────

model Redirect {
  id          String   @id @default(cuid())
  fromPath    String   @unique
  toPath      String
  isPermanent Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ImportBatch {
  id         String       @id @default(cuid())
  filename   String
  status     ImportStatus @default(PENDING)
  type       ImportType   @default(COURSE)
  dryRun     Boolean      @default(true)
  rowCount   Int          @default(0)
  errorCount Int          @default(0)
  summary    Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}
