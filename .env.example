# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/perseus_platform_claude"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# NEXTAUTH_URL is auto-detected in most deployments (set explicitly on Vercel if needed)
# NEXTAUTH_URL="https://yourdomain.com"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave blank in development — Nodemailer auto-creates an Ethereal test account
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASS="your-sendgrid-api-key"
# SMTP_FROM='"Perseus Platform" <noreply@yourdomain.com>'

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
